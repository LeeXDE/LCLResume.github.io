# 复制为 .env.local（勿提交 Git）— 任选其一即可

# ① DeepSeek（推荐，国内可访问，新用户赠免费额度）
# https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-...

# ② 硅基流动（国内，多模型每日免费额度）
# https://cloud.siliconflow.cn → API 密钥
# SILICONFLOW_API_KEY=sk-...

# ③ 智谱 AI（glm-4-flash 免费档）
# https://open.bigmodel.cn → API Keys
# ZHIPU_API_KEY=...

# 高级：自定义兼容接口
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_API_KEY=sk-...
# AI_MODEL=deepseek-chat

# 可选：联网搜索
# TAVILY_API_KEY=tvly-...
