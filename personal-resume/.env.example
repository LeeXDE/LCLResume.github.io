# 复制为 .env.local（勿提交 Git）

# 推荐：Groq 免费 API（OpenAI 兼容，注册即可用）
# https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_...

# 或使用其他兼容接口（二选一即可）
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=google/gemma-2-9b-it:free

# 可选：联网搜索（Tavily 有免费额度 https://tavily.com）
# TAVILY_API_KEY=tvly-...
