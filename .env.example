# 复制为 .env.local（勿提交 Git）

# ① 硅基流动（推荐：国内有免费额度，适合简历助手）
# https://cloud.siliconflow.cn → 注册 → API 密钥
# Vercel 变量名：SILICONFLOW_API_KEY
SILICONFLOW_API_KEY=sk-...

# ② 智谱 glm-4-flash（有免费档）
# https://open.bigmodel.cn
# ZHIPU_API_KEY=...

# ③ DeepSeek API（按量计费，需充值；不能替代网页版嵌入）
# https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-...

# 可选：联网搜索
# TAVILY_API_KEY=tvly-...
